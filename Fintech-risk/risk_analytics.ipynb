   "source": [
    "# ── Q1: Fraud value by merchant category ──────────────────────────────────\n",
    "# Business question: Which MCC categories should we tighten controls on first?\n",
    "# A category with high fraud COUNT may matter less than one with high fraud VALUE.\n",
    "\n",
    "q1 = con.execute(\"\"\"\n",
    "    SELECT\n",
    "        mcc,\n",
    "        COUNT(*)                                                AS total_txns,\n",
    "        SUM(CASE WHEN is_fraud = 1 THEN 1 ELSE 0 END)          AS fraud_count,\n",
    "        ROUND(SUM(CASE WHEN is_fraud = 1 THEN amount ELSE 0 END), 2)\n",
    "                                                                AS fraud_value,\n",
    "        ROUND(SUM(amount), 2)                                   AS total_value,\n",
    "        ROUND(\n",
    "            100.0 * SUM(CASE WHEN is_fraud = 1 THEN amount ELSE 0 END)\n",
    "            / NULLIF(SUM(amount), 0), 2\n",
    "        )                                                       AS fraud_value_pct\n",
    "    FROM txn\n",
    "    GROUP BY mcc\n",
    "    ORDER BY fraud_value DESC\n",
    "\"\"\").df()\n",
    "\n",
    "print('=== Q1: Fraud Value by Merchant Category ===')\n",
    "print(q1.to_string(index=False))\n",
    "top = q1.iloc[0]\n",
    "print()\n",
    "print(f'RECOMMENDATION: \"{top[\"mcc\"]}\" accounts for ${top[\"fraud_value\"]:,.0f} in fraud value '\n",
    "      f'({top[\"fraud_value_pct\"]}% of its total volume). Recommend step-up authentication '\n",
    "      f'for all {top[\"mcc\"]} transactions above median amount — highest ROI fraud control '\n",
    "      f'available for this portfolio.')"
   ]
