   "source": [
    "# ── Q2: Fraud rate by hour-of-day ─────────────────────────────────────────\n",
    "# Business question: Should we apply stricter real-time rules during off-hours?\n",
    "# Tighter thresholds at low-volume hours reduces fraud with minimal legitimate impact.\n",
    "\n",
    "q2 = con.execute(\"\"\"\n",
    "    SELECT\n",
    "        hour,\n",
    "        COUNT(*)                                                AS total_txns,\n",
    "        SUM(CASE WHEN is_fraud = 1 THEN 1 ELSE 0 END)          AS fraud_count,\n",
    "        ROUND(\n",
    "            100.0 * SUM(CASE WHEN is_fraud = 1 THEN 1 ELSE 0 END)\n",
    "            / COUNT(*), 2\n",
    "        )                                                       AS fraud_rate_pct,\n",
    "        ROUND(AVG(amount), 2)                                   AS avg_txn_amount\n",
    "    FROM txn\n",
    "    GROUP BY hour\n",
    "    ORDER BY hour\n",
    "\"\"\").df()\n",
    "\n",
    "threshold = q2['fraud_rate_pct'].quantile(0.80)\n",
    "high_risk_hours = q2[q2['fraud_rate_pct'] >= threshold]['hour'].tolist()\n",
    "\n",
    "print('=== Q2: Fraud Rate by Hour of Day ===')\n",
