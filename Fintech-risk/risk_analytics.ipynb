   "source": [
    "# ── Q5: Velocity fraud detection ──────────────────────────────────────────\n",
    "# Business question: Can we identify accounts showing abnormal transaction\n",
    "# frequency using SQL alone — without a model? Yes. This is a classic\n",
    "# rules-engine query used in real-time fraud prevention.\n",
    "\n",
    "import numpy as np\n",
    "txn_v = txn.copy()\n",
    "fraud_accounts = [f'ACC{i:04d}' for i in range(30)]\n",
    "legit_accounts = [f'ACC{i:04d}' for i in range(30, 500)]\n",
    "txn_v['account_id'] = np.where(\n",
    "    txn_v['is_fraud'] == 1,\n",
    "    np.random.choice(fraud_accounts, len(txn_v)),\n",
    "    np.random.choice(legit_accounts, len(txn_v))\n",
    ")\n",
    "\n",
    "q5 = con.execute(\"\"\"\n",
    "    SELECT\n",
    "        account_id,\n",
    "        COUNT(*)                                            AS txn_count,\n",
    "        ROUND(SUM(amount), 2)                               AS total_spend,\n",
    "        ROUND(AVG(amount), 2)                               AS avg_txn,\n",
    "        SUM(CASE WHEN is_fraud = 1 THEN 1 ELSE 0 END)      AS fraud_txns,\n",
    "        ROUND(\n",
    "            100.0 * SUM(CASE WHEN is_fraud = 1 THEN 1 ELSE 0 END)\n",
    "            / COUNT(*), 1\n",
    "        )                                                   AS fraud_rate_pct,\n",
    "        COUNT(DISTINCT mcc)                                 AS distinct_mcc\n",
    "    FROM txn_v\n",
    "    GROUP BY account_id\n",
    "    HAVING COUNT(*) >= 5\n",
    "       AND SUM(CASE WHEN is_fraud = 1 THEN 1 ELSE 0 END) > 0\n",
    "    ORDER BY fraud_rate_pct DESC, total_spend DESC\n",
    "    LIMIT 15\n",
    "\"\"\").df()\n",
    "\n",
    "print('=== Q5: Top 15 High-Velocity Fraud Accounts ===')\n",
    "print(q5.to_string(index=False))\n",
    "print()\n",
    "print(f'RECOMMENDATION: Accounts with fraud_rate_pct > 50% AND distinct_mcc > 3 indicate '\n",
    "      f'account takeover or synthetic identity — multi-category spend is inconsistent '\n",
    "      f'with a single legitimate cardholder. Recommend immediate manual review and '\n",
    "      f'temporary transaction limits pending re-verification.')"
   ]
