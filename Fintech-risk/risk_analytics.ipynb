    "# ── Q3: Fraud exposure by customer segment ────────────────────────────────\n",
    "# Business question: Which segment needs the most urgent intervention?\n",
    "# Dollar-weighted view is more actionable than count-based fraud rate alone.\n",
    "\n",
    "q3 = con.execute(\"\"\"\n",
    "    SELECT\n",
    "        segment,\n",
    "        COUNT(*)                                                    AS total_txns,\n",
    "        ROUND(SUM(amount), 2)                                       AS total_volume,\n",
    "        ROUND(SUM(CASE WHEN is_fraud = 1 THEN amount ELSE 0 END), 2)\n",
    "                                                                    AS fraud_volume,\n",
    "        ROUND(\n",
    "            100.0 * SUM(CASE WHEN is_fraud = 1 THEN amount ELSE 0 END)\n",
    "            / NULLIF(SUM(amount), 0), 2\n",
    "        )                                                           AS fraud_volume_pct,\n",
    "        ROUND(AVG(CASE WHEN is_fraud = 1 THEN amount END), 2)       AS avg_fraud_amount\n",
    "    FROM txn\n",
    "    GROUP BY segment\n",
    "    ORDER BY fraud_volume DESC\n",
    "\"\"\").df()\n",
